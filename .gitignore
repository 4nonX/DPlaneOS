# D-PlaneOS .gitignore

# ── Compiled binaries ─────────────────────────────────────────────────────────
daemon/dplaned
daemon/dplaned-*
*.exe
*.out

# ── Go build artifacts ────────────────────────────────────────────────────────
daemon/vendor/
# Note: go.sum IS committed (reproducible builds)

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db.backup
*.sqlite
*.sqlite3

# ── Release tarballs ──────────────────────────────────────────────────────────
*.tar.gz
*.tar.xz
*.zip
dplaneos-v*.tar.*
release*/
dist/

# ── Frontend build output (intermediate dir, outDir is ../app) ────────────────
app-built/
app-react/dist/

# ── rclone config (contains credentials) ─────────────────────────────────────
/etc/dplaneos/rclone.conf
rclone.conf

# ── Sync conflict files ───────────────────────────────────────────────────────
# Syncthing
*.sync-conflict-*
.stfolder
.stignore
# Dropbox
*.dropbox
.dropbox
.dropbox.attr
# Nextcloud / ownCloud
*_conflict-*
# OneDrive
*.~lock.*

# ── macOS artifacts ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems
.VolumeIcon.icns

# ── Windows artifacts ─────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux desktop artifacts ───────────────────────────────────────────────────
.directory
.Trash-*

# ── Local dev / IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test artifacts ────────────────────────────────────────────────────────────
/tmp/
coverage.out
coverage.html

# ── Debug / CI output files ─────────────────────────────────────────────────
*_output.txt
*_test.txt
diff.txt
diff_*.txt
build_*.txt
handlers_*.txt
zfs_*.txt
whitelist_*.go
zfs_*.go
*.bak

# ── NixOS build outputs ───────────────────────────────────────────────────────
nixos/result
nixos/result-*

# ── SSH keys / secrets ────────────────────────────────────────────────────────
*.pem
*.key
*.crt
id_rsa
id_ed25519
*.p12
*.pfx
